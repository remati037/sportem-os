# ─────────────────────────────────────────────────────────────
# Sportem app — primer okruženja
# Kopiraj ovaj fajl u `.env.local` i popuni pravim vrednostima.
# `.env*` je u .gitignore — nikad ne commit-ovati prave ključeve.
# NEXT_PUBLIC_* varijable su vidljive u browseru; sve ostalo je samo server.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Korak 0.4/0.5) ──────────────────────────────────
# URL projekta i anon ključ (bezbedni za klijent, štite ih RLS politike)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role ključ — zaobilazi RLS, ISKLJUČIVO server (webhook, cron, seed). Nikad na klijent.
SUPABASE_SERVICE_ROLE_KEY=

# ── WooCommerce (Korak 1.2/1.3) ───────────────────────────────
# REST API bazni URL — za `npm run backfill -- --reconcile` (poređenje sa Woo).
# Primer: https://sportem.rs/wp-json/wc/v3
WOO_API_URL=
# REST API ključevi (read-only je dovoljno) za povlačenje porudžbina sa sportem.rs
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
# Tajni ključ za HMAC proveru potpisa webhook-a (x-wc-webhook-signature)
WOO_WEBHOOK_SECRET=

# ── Sentry (Korak 0.6) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
# Token za upload source map-a pri build-u (samo CI/Vercel)
SENTRY_AUTH_TOKEN=
# org i project slug (nisu tajna) — za withSentryConfig u next.config.ts
SENTRY_ORG=
SENTRY_PROJECT=

# ── Web Push / VAPID (Korak 1.9) ──────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Aplikacija ────────────────────────────────────────────────
# Javni URL app-a (za push, apsolutne linkove, PDF, invite redirect).
# Prod: https://app.sportem.rs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── RLS test (Korak 0.5) — samo za `npm run rls:test`, ne za app ──
# Kredencijali test naloga; drži ih u .env.test.local (gitignore), ne ovde.
RLS_TEST_ADMIN_EMAIL=
RLS_TEST_ADMIN_PASSWORD=
RLS_TEST_LOGISTICS_EMAIL=
RLS_TEST_LOGISTICS_PASSWORD=
